// =====================================================================
// Soie Clinic — relational schema (PostgreSQL)
//
// Money is stored as integer piasters (EGP * 100) to avoid floating
// point drift. Revenue is derived from Payment rows; reports aggregate
// it rather than duplicating totals in a table of their own.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------- enums

enum Role {
  PATIENT
  DOCTOR
  STAFF
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  WALLET
}

enum PaymentStatus {
  PAID
  REFUNDED
  VOID
}

enum CategoryKind {
  SERVICE
  PRODUCT
}

enum StockMoveType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SUPPLIES
  MARKETING
  MAINTENANCE
  SALARIES
  OTHER
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  REMINDER
  SYSTEM
}

enum ReviewSource {
  WEB
  WHATSAPP
  GOOGLE
}

// ---------------------------------------------------------------- auth

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  phone           String?
  role            Role      @default(PATIENT)
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  doctor          Doctor?
  appointments    Appointment[]        @relation("PatientAppointments")
  notifications   Notification[]
  reviews         Review[]
  auditLogs       AuditLog[]
  passwordResets  PasswordResetToken[]
  recordedPayments Payment[]           @relation("RecordedPayments")
  recordedExpenses Expense[]           @relation("RecordedExpenses")
  stockMoves      StockMove[]

  @@index([role])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  purpose   String    @default("password_reset") // or "email_verify"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------- staff

model Doctor {
  id            String  @id @default(cuid())
  userId        String? @unique // optional login account for the doctor
  name          String
  slug          String  @unique
  specialty     String
  bio           String  @default("")
  photoUrl      String?
  instagramUrl  String?
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)
  monthlySalaryCents Int     @default(0)
  commissionPct      Decimal @default(0) @db.Decimal(5, 2) // % of referred revenue
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  schedules    DoctorSchedule[]
  services     ServiceDoctor[]
  appointments Appointment[]    @relation("DoctorAppointments")
  referrals    Appointment[]    @relation("ReferredAppointments")
  commissions  CommissionEntry[]
  salaries     SalaryRecord[]
}

// One working block per weekday; absence of a row = day off.
model DoctorSchedule {
  id          String @id @default(cuid())
  doctorId    String
  weekday     Int // 0 = Sunday … 6 = Saturday
  startMinute Int // minutes since midnight, e.g. 600 = 10:00
  endMinute   Int

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, weekday])
}

// ---------------------------------------------------------------- catalogue

model Category {
  id       String       @id @default(cuid())
  name     String
  slug     String       @unique
  kind     CategoryKind
  services Service[]
  products Product[]
}

model Service {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String  @default("")
  durationMin Int     @default(60)
  priceCents  Int     @default(0)
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  categoryId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category     Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  doctors      ServiceDoctor[]
  appointments Appointment[]
}

model ServiceDoctor {
  serviceId String
  doctorId  String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@id([serviceId, doctorId])
}

model Product {
  id                String  @id @default(cuid())
  name              String
  slug              String  @unique
  description       String  @default("")
  sku               String? @unique
  imageUrl          String?
  priceCents        Int     @default(0)
  stockQty          Int     @default(0)
  lowStockThreshold Int     @default(5)
  isActive          Boolean @default(true)
  categoryId        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category   Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockMoves StockMove[]
  sales      ProductSale[]
}

model StockMove {
  id          String        @id @default(cuid())
  productId   String
  type        StockMoveType
  qty         Int // positive for in, negative for out
  note        String?
  createdById String?
  createdAt   DateTime      @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
}

model ProductSale {
  id             String   @id @default(cuid())
  productId      String
  qty            Int
  unitPriceCents Int
  totalCents     Int
  soldAt         DateTime @default(now())

  product Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  payment Payment?

  @@index([soldAt])
}

// ---------------------------------------------------------------- scheduling

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  doctorId  String
  serviceId String
  startsAt  DateTime
  endsAt    DateTime
  status    AppointmentStatus @default(PENDING)
  notes     String? // patient's note
  adminNotes String? // internal
  cancelReason String?
  referredByDoctorId String? // commission credit
  rescheduledFromId  String? @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  patient        User         @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor         Doctor       @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Restrict)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  referredBy     Doctor?      @relation("ReferredAppointments", fields: [referredByDoctorId], references: [id], onDelete: SetNull)
  rescheduledFrom Appointment? @relation("Reschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo   Appointment? @relation("Reschedule")
  payment        Payment?
  commission     CommissionEntry?

  @@index([doctorId, startsAt])
  @@index([patientId, startsAt])
  @@index([status, startsAt])
}

// ---------------------------------------------------------------- finance

model Payment {
  id            String        @id @default(cuid())
  appointmentId String?       @unique
  productSaleId String?       @unique
  amountCents   Int
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PAID)
  paidAt        DateTime      @default(now())
  note          String?
  recordedById  String?

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  productSale ProductSale? @relation(fields: [productSaleId], references: [id], onDelete: SetNull)
  recordedBy  User?        @relation("RecordedPayments", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([paidAt])
  @@index([status, paidAt])
}

model CommissionEntry {
  id            String   @id @default(cuid())
  doctorId      String
  appointmentId String   @unique
  pct           Decimal  @db.Decimal(5, 2)
  amountCents   Int
  createdAt     DateTime @default(now())

  doctor      Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([doctorId, createdAt])
}

model SalaryRecord {
  id              String    @id @default(cuid())
  doctorId        String
  year            Int
  month           Int // 1–12
  baseCents       Int
  bonusCents      Int       @default(0)
  deductionsCents Int       @default(0)
  commissionCents Int       @default(0)
  netCents        Int
  paidAt          DateTime?
  note            String?
  createdAt       DateTime  @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, year, month])
}

model Expense {
  id           String          @id @default(cuid())
  category     ExpenseCategory
  description  String
  amountCents  Int
  incurredAt   DateTime        @default(now())
  recordedById String?
  createdAt    DateTime        @default(now())

  recordedBy User? @relation("RecordedExpenses", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([incurredAt])
  @@index([category, incurredAt])
}

// ---------------------------------------------------------------- engagement

model Review {
  id         String       @id @default(cuid())
  userId     String?
  authorName String
  rating     Int // 1–5
  text       String
  source     ReviewSource @default(WEB)
  isApproved Boolean      @default(false)
  createdAt  DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isApproved, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model ContactRequest {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  message   String
  handledAt DateTime?
  createdAt DateTime  @default(now())

  @@index([handledAt, createdAt])
}

// ---------------------------------------------------------------- platform

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // e.g. "appointment.confirm"
  entity    String
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, createdAt])
  @@index([userId, createdAt])
}

model Setting {
  key   String @id
  value String
}
