{
  "name": "soie-clinic",
  "version": "1.0.0",
  "private": true,
  "description": "Soie Clinic — public website and clinic management system (Next.js + PostgreSQL + Prisma)",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:dev": "node scripts/dev-db.mjs",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "^15.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "embedded-postgres": "^17.2.0-beta.15",
    "prisma": "^6.16.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
