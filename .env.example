# ---------------------------------------------------------------------
# Soie Clinic — environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------

# PostgreSQL connection. For local development run `npm run db:dev`
# (embedded PostgreSQL) and use the URL it prints:
DATABASE_URL="postgresql://soie:soie_dev_password@localhost:5432/soie_clinic"

# 32+ random bytes, e.g. `openssl rand -base64 48`. Signing key for
# session JWTs — rotating it invalidates all sessions.
AUTH_SECRET="change-me-to-a-long-random-secret"

# Absolute origin of the deployed app (used in emails and CSRF checks)
APP_ORIGIN="http://localhost:3000"

# SMTP for transactional mail (password reset, verification).
# Leave empty in development: emails are logged to the server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Soie Clinic <no-reply@soieclinic.com>"

# Seed credentials for the first admin account (used by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@soieclinic.com"
SEED_ADMIN_PASSWORD="ChangeMe!Soie2026"
